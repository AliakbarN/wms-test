{
  "info": {
    "_postman_id": "3809448e-753e-4c4e-90bc-3ff8584e6f0e",
    "name": "ERP Inventory API",
    "description": "Laravel inventory API. Login is public and returns a Laravel Sanctum bearer token. All other API requests inherit bearer authentication from the collection. Run master-data creates before transactional examples. Money is sent as decimal strings. Client orders intentionally contain no batch or price fields.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "23534658"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login returns a Sanctum bearer token', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token_type).to.eql('Bearer');",
                  "  pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.user).to.have.property('email');",
                  "  pm.expect(json.user).to.not.have.property('password');",
                  "  pm.expect(json.user).to.not.have.property('is_admin');",
                  "  pm.environment.set('token', json.token);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{login_email}}\",\n  \"password\": \"{{login_password}}\",\n  \"device_name\": \"{{device_name}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Invalid login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invalid credentials rejected', function () {",
                  "  pm.response.to.have.status(422);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('errors');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{login_email}}\",\n  \"password\": \"wrong-password\",\n  \"device_name\": \"{{device_name}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            },
            "description": "Expected 422 with a generic credential validation error. No token is created."
          },
          "response": []
        },
        {
          "name": "Status without token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unauthenticated request is rejected', function () { pm.response.to.have.status(401); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "status"
              ]
            },
            "description": "Expected 401. All /api/v1 routes except token creation require Sanctum authentication."
          },
          "response": []
        },
        {
          "name": "Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Authenticated', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "status"
              ]
            },
            "description": "Verifies the Sanctum token and API routing."
          },
          "response": []
        },
        {
          "name": "Current user",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/user",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
